# Base URL of the Go backend (origin must be listed in the server's
# CORS_ALLOWED_ORIGINS for cross-origin requests to succeed).
VITE_API_BASE_URL=http://localhost:8080

# Firebase web config (public; obtain from Firebase console > Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
